{
  "name": "immersive-translate-code",
  "displayName": "Immersive Translate - Code",
  "icon": "assets/icon.png",
  "description": "Immersive translation for Visual Studio Code",
  "version": "0.0.3",
  "publisher": "lanqun520",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/liber-gong/immersive-translate-code"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "immersive-translate-code.toggle",
        "title": "Immersive Translate: Toggle"
      },
      {
        "command": "immersive-translate-code.reset",
        "title": "Immersive Translate: Reset"
      }
    ],
    "keybindings": [
      {
        "command": "immersive-translate-code.toggle",
        "key": "ctrl+alt+t",
        "mac": "ctrl+cmd+t"
      }
    ],
    "configuration": {
      "title": "Immersive Translate - Code",
      "properties": {
        "immersive-translate-code.provider": {
          "type": "string",
          "default": "google-translate",
          "enum": [
            "google-translate",
            "openai",
            "deepseek",
            "gemini",
            "custom",
            "bedrock"
          ],
          "enumDescriptions": [
            "Google Translate (Free, no API key required)",
            "OpenAI (requires API key)",
            "DeepSeek (requires API key)",
            "Gemini (requires API key)",
            "Custom OpenAI-compatible endpoint (requires API key, baseURL, model)",
            "AWS Bedrock (requires AWS credentials, region, model ID)"
          ],
          "description": "Translation provider.",
          "order": 0
        },
        "immersive-translate-code.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for the selected provider.",
          "order": 1
        },
        "immersive-translate-code.baseURL": {
          "type": "string",
          "default": "",
          "description": "Custom API base URL (only for 'custom' provider, or to override preset URL).",
          "order": 2
        },
        "immersive-translate-code.model": {
          "type": "string",
          "default": "",
          "description": "Model name (only for 'custom' provider, or to override preset model).",
          "order": 3
        },
        "immersive-translate-code.awsRegion": {
          "type": "string",
          "default": "",
          "description": "AWS region for Bedrock (e.g., 'us-east-1').",
          "order": 4
        },
        "immersive-translate-code.awsProfile": {
          "type": "string",
          "default": "",
          "description": "AWS profile name for Bedrock SSO (leave empty for default credential chain).",
          "order": 5
        },
        "immersive-translate-code.awsBedrockModelId": {
          "type": "string",
          "default": "",
          "description": "AWS Bedrock model ID or inference profile ID.",
          "order": 6
        },
        "immersive-translate-code.sourceLanguage": {
          "type": "string",
          "default": "en",
          "description": "Source language code (e.g., 'en', 'auto').",
          "order": 7
        },
        "immersive-translate-code.targetLanguage": {
          "type": "string",
          "default": "zh-CN",
          "description": "Target language code (e.g., 'zh-CN', 'en').",
          "order": 8
        }
      }
    }
  },
  "scripts": {
    "compile": "pnpm run check-types && node esbuild.js",
    "compile:production": "pnpm run check-types && node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "node --import tsx --test src/test/*.test.ts",
    "vscode:prepublish": "pnpm run compile:production",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.1.3",
    "typescript-eslint": "^8.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1025.0",
    "@aws-sdk/credential-providers": "^3.1025.0"
  }
}
